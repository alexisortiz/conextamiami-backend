# Copy to .env — never commit .env
PORT=3001
BRIDGE_API_BASE=https://api.bridgedataoutput.com/api/v2/OData
BRIDGE_DATASET=miamire
BRIDGE_SERVER_TOKEN=

# Solo en Lambda: no hace falta en local si usas BRIDGE_SERVER_TOKEN arriba
# BRIDGE_SERVER_TOKEN_SSM_PARAM=/conextamiami/dev/bridge-server-token

# Comma-separated origins, or * for local development
CORS_ORIGIN=*

# En prod: lista de orígenes que pueden llamar a /api (o se deduce de CORS_ORIGIN si no es *)
# ALLOWED_ORIGINS=https://conextamiami.com

# Opcional: clave pública compartida con VITE_PUBLIC_API_KEY en el front
# PUBLIC_CLIENT_API_KEY=
